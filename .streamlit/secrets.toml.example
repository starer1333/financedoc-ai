# Copy these values into Streamlit Community Cloud > App > Settings > Secrets.
# Do not commit a real .streamlit/secrets.toml file.

# DeepSeek via SiliconFlow
# Any one of DEEPSEEK, DEEPSEEK_API_KEY, SILICONFLOW_API_KEY, or SILICONFLOW is accepted.
DEEPSEEK = "your_siliconflow_api_key"
DEEPSEEK_MODEL = "deepseek-ai/DeepSeek-V3.2"
DEEPSEEK_BASE_URL = "https://api.siliconflow.cn/v1/chat/completions"
