# Copy these values into Streamlit Community Cloud > App > Settings > Secrets.
# Do not commit a real .streamlit/secrets.toml file.

# OpenAI
OPENAI_API_KEY = "your_openai_api_key"
OPENAI_MODEL = "gpt-4o-mini"
OPENAI_BASE_URL = "https://api.openai.com/v1/chat/completions"

# DeepSeek
# Either DEEPSEEK_API_KEY or DEEPSEEK is accepted.
DEEPSEEK_API_KEY = "your_deepseek_api_key"
DEEPSEEK = "your_deepseek_api_key"
DEEPSEEK_MODEL = "deepseek-v4-flash"
DEEPSEEK_BASE_URL = "https://api.deepseek.com/chat/completions"

# Kimi / Moonshot
# Any one of KIMI_API_KEY, KIMI, MOONSHOT_API_KEY, or MOONSHOT is accepted.
KIMI_API_KEY = "your_kimi_or_moonshot_api_key"
KIMI_MODEL = "moonshot-v1-8k"
KIMI_BASE_URL = "https://api.moonshot.cn/v1/chat/completions"
